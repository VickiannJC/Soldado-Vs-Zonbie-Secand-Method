        <Component class="javax.swing.JTextArea" name="infoText">
          <Properties>
            <Property name="background" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
              <Color blue="0" green="0" red="0" type="rgb"/>
            </Property>
            <Property name="columns" type="int" value="20"/>
            <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
              <Font name="OCR A Extended" size="18" style="0"/>
            </Property>
            <Property name="foreground" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
              <Color blue="0" green="ff" red="0" type="rgb"/>
            </Property>
            <Property name="lineWrap" type="boolean" value="true"/>
            <Property name="rows" type="int" value="5"/>
            <Property name="text" type="java.lang.String" value="In a world ravaged by apocalypse, where humanity faces a constant threat from&#xa;hordes of bloodthirsty undead, emerges a legend that has captured &#xa;the imagination of those still struggling to survive: the legendary Sacred Diamond.&#xa;&#xa;It is said that this diamond, whose existence is lost in the mists of time,&#xa;possesses unparalleled power: the ability to transform all living beings &#xa;on earth into followers of either side, be it the relentless soldiers &#xa;fighting for humanity&apos;s survival, or the ruthless zombies seeking to consume &#xa;everything in their path.&#xa;&#xa;The key to unraveling the whereabouts of this mysterious diamond lies in an &#xa;ancient mathematical secret, guarded jealously by generations.&#xa;It is said that only those capable of comprehending and applying the &#xa;numerical method of the secant will be able to decipher &#xa;the riddles that lead to the Sacred Diamond.&#xa;&#xa;Now, two brave and cunning players face a transcendent choice: &#xa;to join the ranks of the soldiers or succumb to the darkness of the zombies? &#xa;The battle for the Sacred Diamond is about to begin. &#xa;Are you prepared to choose your side and unravel the &#xa;mathematical secrets that will determine the fate of humanity?&#xa;The future of this world lies in your hands."/>
            <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
              <Border info="org.netbeans.modules.form.compat2.border.MatteColorBorderInfo">
                <MatteColorBorder bottom="5" left="5" right="5" top="5">
                  <Color PropertyName="color" blue="33" green="33" red="33" type="rgb"/>
                </MatteColorBorder>
              </Border>
            </Property>
            <Property name="caretColor" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
              <Color blue="66" green="66" red="66" type="rgb"/>
            </Property>
            <Property name="selectedTextColor" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
              <Color blue="33" green="ff" red="0" type="rgb"/>
            </Property>
            <Property name="selectionColor" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
              <Color blue="0" green="ff" red="33" type="rgb"/>
            </Property>
          </Properties>
        </Component>
